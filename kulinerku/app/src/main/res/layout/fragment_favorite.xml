<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorAppBackground">

    <!-- Scrollable content for header and list -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll_favorite_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="16dp">

            <!-- Editorial Header -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Dapur Favorit"
                android:textColor="?attr/colorAppText"
                android:textSize="28sp"
                android:textStyle="bold"
                android:fontFamily="@font/fraunces" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Koleksi resep masakan pilihan Anda yang dapat diakses kapan saja."
                android:textColor="?attr/colorAppText"
                android:textSize="14sp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="24dp" />

            <!-- Favorites List (Reuses MealAdapter grid style) -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_favorites"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:layout_marginBottom="80dp"
                tools:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                tools:spanCount="2"
                tools:listitem="@layout/item_meal" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Empty State Layout -->
    <LinearLayout
        android:id="@+id/layout_empty_favorite"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tv_empty_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Dapur Masih Kosong"
            android:textColor="?attr/colorAppText"
            android:textSize="22sp"
            android:textStyle="bold"
            android:fontFamily="@font/fraunces"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tv_empty_message"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Telusuri resep masakan menarik di halaman Jelajah dan klik tombol hati untuk menyimpannya di sini!"
            android:textColor="?attr/colorAppText"
            android:textSize="14sp"
            android:gravity="center"
            android:lineSpacingExtra="3dp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
