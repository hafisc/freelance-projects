<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorAppBackground">

    <!-- Loading Indicator -->
    <ProgressBar
        android:id="@+id/progress_bar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Error State Layout -->
    <LinearLayout
        android:id="@+id/layout_error"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tv_error_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Koneksi Terputus"
            android:textColor="?attr/colorAppText"
            android:textSize="22sp"
            android:textStyle="bold"
            android:fontFamily="@font/fraunces"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tv_error_message"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Waduh, dapur kami kehilangan sinyal! Periksa koneksi internetmu dan coba lagi."
            android:textColor="?attr/colorAppText"
            android:textSize="14sp"
            android:gravity="center"
            android:layout_marginBottom="24dp" />

        <Button
            android:id="@+id/btn_retry"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Coba Lagi"
            android:backgroundTint="?attr/colorAppPrimary"
            android:textColor="@color/white"
            android:fontFamily="@font/plus_jakarta_sans"
            android:paddingHorizontal="24dp"
            android:paddingVertical="12dp" />
    </LinearLayout>

    <!-- Main Content -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="16dp">

            <!-- Editorial Header -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Eksplorasi Kuliner"
                android:textColor="?attr/colorAppText"
                android:textSize="28sp"
                android:textStyle="bold"
                android:fontFamily="@font/fraunces" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Temukan berbagai resep masakan terbaik khas Nusantara."
                android:textColor="?attr/colorAppText"
                android:textSize="14sp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="16dp" />

            <!-- Modern Search Bar -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/layout_search"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:startIconDrawable="@drawable/ic_search"
                app:startIconTint="?attr/colorAppText"
                app:hintEnabled="false"
                app:boxCornerRadiusTopStart="24dp"
                app:boxCornerRadiusTopEnd="24dp"
                app:boxCornerRadiusBottomStart="24dp"
                app:boxCornerRadiusBottomEnd="24dp"
                app:boxStrokeColor="?attr/colorAppStrokeGlass"
                app:boxBackgroundColor="?attr/colorAppSurface"
                app:endIconMode="clear_text"
                app:endIconTint="?attr/colorAppText">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_search"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Cari resep makanan..."
                    android:textColor="?attr/colorAppText"
                    android:textColorHint="?attr/colorAppText"
                    android:textSize="14sp"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:inputType="text"
                    android:imeOptions="actionSearch"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Horizontal Categories list -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_categories"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp"
                tools:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                tools:listitem="@layout/item_category" />

            <!-- Subtitle for Meals list -->
            <TextView
                android:id="@+id/tv_section_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Menu Pilihan"
                android:textColor="?attr/colorAppText"
                android:textSize="20sp"
                android:textStyle="bold"
                android:fontFamily="@font/fraunces"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="8dp" />

            <!-- Meals list (Grid of 2 columns) -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_meals"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:layout_marginBottom="80dp"
                tools:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                tools:spanCount="2"
                tools:listitem="@layout/item_meal" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
