<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/card_meal"
    android:layout_width="match_parent"
    android:layout_height="220dp"
    android:layout_margin="8dp"
    app:cardBackgroundColor="?attr/colorAppSurface"
    app:cardElevation="2dp"
    app:strokeWidth="1dp"
    app:strokeColor="?attr/colorAppStrokeGlass"
    app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.Kulinerku.MealCard"
    android:clipToOutline="true"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Meal Thumbnail -->
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/iv_meal_thumb"
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:scaleType="centerCrop"
            android:contentDescription="Gambar Makanan"
            app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.Kulinerku.MealCard.Image" />

        <!-- Meal Content Container -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center_vertical"
            android:paddingHorizontal="12dp"
            android:paddingVertical="8dp">

            <!-- Meal Title -->
            <TextView
                android:id="@+id/tv_meal_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="?attr/colorAppText"
                android:textSize="14sp"
                android:textStyle="bold"
                android:ellipsize="end"
                android:maxLines="2"
                android:text="Nama Makanan" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
