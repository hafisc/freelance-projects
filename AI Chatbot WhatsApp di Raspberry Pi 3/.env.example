# === Konfigurasi WhatsApp AI Chatbot ===

# Prefix command untuk trigger bot (default: !ai)
COMMAND_PREFIX=!ai

# Batas maksimal karakter input dari user
MAX_CHARS=1500

# Batas maksimal karakter balasan AI per segmen
MAX_REPLY_CHARS=3500

# Path binary PicoClaw CLI
PICOCLAW_BIN=/usr/local/bin/picoclaw

# Folder penyimpanan session WhatsApp Baileys
BAILEYS_AUTH_DIR=./auth_info_baileys

# Daftar nomor yang diizinkan (format internasional tanpa +, pisah koma)
# Kosongkan untuk mengizinkan semua nomor (mode testing)
# Contoh: 6281234567890,6289876543210
ALLOWED_NUMBERS=

# Nama bot (untuk logging)
BOT_NAME=AI WhatsApp Assistant

# Level logging: fatal, error, warn, info, debug, trace
LOG_LEVEL=info

# Timeout eksekusi PicoClaw dalam milidetik (default: 120000 = 2 menit)
PICOCLAW_TIMEOUT_MS=120000
