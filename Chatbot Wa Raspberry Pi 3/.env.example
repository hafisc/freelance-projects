# ==========================================
# Konfigurasi Bot WhatsApp AI
# ==========================================

# --- Bot Settings ---
COMMAND_PREFIX=!ai
BOT_NAME=AI WhatsApp Assistant
ALLOWED_NUMBERS=

# --- Input/Output Limits ---
MAX_CHARS=1500
MAX_REPLY_CHARS=3500

# --- Groq AI API ---
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TIMEOUT_MS=120000

# --- Baileys (WhatsApp Session) ---
BAILEYS_AUTH_DIR=./auth_info_baileys

# --- Logging ---
LOG_LEVEL=info
